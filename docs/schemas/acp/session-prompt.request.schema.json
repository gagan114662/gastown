{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gastown.dev/schemas/acp/session-prompt.request.schema.json",
  "title": "ACP Session Prompt Request",
  "type": "object",
  "additionalProperties": false,
  "required": ["jsonrpc", "id", "method", "params"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": {},
    "method": { "const": "session/prompt" },
    "params": {
      "type": "object",
      "additionalProperties": true,
      "required": ["sessionId", "prompt"],
      "properties": {
        "sessionId": { "type": "string", "minLength": 1 },
        "prompt": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["type", "text"],
            "properties": {
              "type": { "const": "text" },
              "text": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
