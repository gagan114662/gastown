{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://gastown.dev/schemas/acp/session-new.response.schema.json",
  "title": "ACP Session New Response",
  "type": "object",
  "additionalProperties": false,
  "required": ["jsonrpc", "id", "result"],
  "properties": {
    "jsonrpc": { "const": "2.0" },
    "id": {},
    "result": {
      "type": "object",
      "required": ["sessionId"],
      "properties": {
        "sessionId": { "type": "string", "minLength": 1 },
        "modes": {
          "type": "object",
          "required": ["currentModeId", "availableModes"],
          "properties": {
            "currentModeId": { "type": "string" },
            "availableModes": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" },
                  "description": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}
