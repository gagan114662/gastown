# .env.agent-ci.example — Secrets template for running CI locally with agent-ci
#
# Copy to .env.agent-ci and fill in values before running:
#   cp .env.agent-ci.example .env.agent-ci
#
# .env.agent-ci is gitignored and must NEVER be committed.
# agent-ci reads this file automatically when present at the project root.
# Reference: https://github.com/redwoodjs/agent-ci

# Codecov upload token — optional for local runs.
# Without this, the "Upload coverage to Codecov" step fails silently
# (fail_ci_if_error: false in ci.yml), so CI still passes.
# Get your token from: https://app.codecov.io/gh/gagan114662/gastown/settings
CODECOV_TOKEN=

# GITHUB_TOKEN — agent-ci auto-injects a mock token for local runs.
# Only set this if a step requires the real GitHub API.
# Leave blank for normal local CI runs.
GITHUB_TOKEN=
